# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Sheets Spreadsheet ID (from the URL: /d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_google_spreadsheet_id_here

# Path to your Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json

# Sheet names (change if your sheets are named differently)
MASTER_SHEET_NAME=Master
SALESMEN_SHEET_NAME=Salesmen
DISTRIBUTORS_SHEET_NAME=Distributors
PRODUCTS_SHEET_NAME=Products